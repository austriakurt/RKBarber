VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Server-side (Vercel Functions)
ADMIN_EMAIL_ALLOWLIST=admin@rk.com
ADMIN_EMAIL=admin@rk.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Public URL used in booking email links (required in production)
PUBLIC_BASE_URL=https://your-domain.vercel.app

# Booking action token security
BOOKING_TOKEN_SECRET=replace-with-a-long-random-string

# Cron endpoint protection (optional but recommended)
CRON_SECRET=replace-with-another-long-random-string

# Free image upload API (recommended primary provider)
IMGBB_API_KEY=your_imgbb_api_key

# SMTP mail config (free provider options: Brevo, Gmail app password, Mailtrap)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
BOOKING_FROM_EMAIL=RK Barbershop <no-reply@your-domain.com>
